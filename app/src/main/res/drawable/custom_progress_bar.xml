<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Transparent background -->
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
            <corners android:radius="50dp"/>
        </shape>
    </item>

    <!-- Progress with shadow -->
    <item android:id="@android:id/progress">
        <clip>
            <layer-list>

                <!-- Shadow stack -->
                <item>
                    <shape>
                        <padding
                            android:left="1dp"
                            android:right="1dp"
                            android:top="1dp"
                            android:bottom="1dp"/>
                        <solid android:color="#00612F"/>
                        <corners android:radius="50dp"/>
                    </shape>
                </item>

                <item>
                    <shape>
                        <padding
                            android:left="1dp"
                            android:right="1dp"
                            android:top="1dp"
                            android:bottom="1dp"/>
                        <solid android:color="#00612F"/>
                        <corners android:radius="50dp"/>
                    </shape>
                </item>

                <item>
                    <shape>
                        <padding
                            android:left="1.5dp"
                            android:right="1.5dp"
                            android:top="1.5dp"
                            android:bottom="1.5dp"/>
                        <solid android:color="#00612F"/>
                        <corners android:radius="50dp"/>
                    </shape>
                </item>

                <!-- Actual progress color -->
                <item>
                    <shape android:shape="rectangle">
                        <solid android:color="#00612F"/>
                        <corners android:radius="50dp"/>
                    </shape>
                </item>

            </layer-list>
        </clip>
    </item>

</layer-list>