<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow layer -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FF8C00"/> <!-- shadow color -->
            <corners android:radius="50dp"/>
            <padding
                android:left="6dp"
                android:right="6dp"
                android:top="6dp"
                android:bottom="6dp"/>
        </shape>
    </item>

    <!-- Actual progress background -->
    <item
        android:left="6dp"
        android:right="6dp"
        android:top="6dp"
        android:bottom="6dp">

        <shape android:shape="rectangle">
            <solid android:color="#FF8C00"/>
            <corners android:radius="50dp"/>
        </shape>

    </item>

</layer-list>