<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_background_bg">

    <FrameLayout
        android:id="@+id/loadingPhase"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/_45sdp"
            android:gravity="top|center_horizontal"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivLogoLoading"
                android:layout_width="280dp"
                android:layout_height="300dp"
                android:contentDescription="Rocket Riper Logo"
                android:scaleType="fitCenter"
                android:src="@drawable/kick_app_logo" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginBottom="@dimen/_32sdp"
            android:orientation="vertical"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingBottom="56dp">

            <LinearLayout
                android:layout_gravity="center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:layout_marginEnd="@dimen/_4sdp"
                android:layout_marginStart="@dimen/_4sdp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Loading  "
                    android:textColor="#EFDFDB"
                    android:textSize="16sp"
                    android:fontFamily="@font/lexend_black" />

                <TextView
                    android:id="@+id/tvLoadingPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0% ......"
                    android:textColor="#EFDFDB"
                    android:textSize="16sp"
                    android:fontFamily="@font/lexend_black"/>

            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_14sdp"
                android:background="@drawable/splash_progress_bar"
                android:paddingHorizontal="4dp">

                <ProgressBar
                    android:id="@+id/progressBarLoading"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_10sdp"
                    android:layout_gravity="center_vertical"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_bar_orange" />

            </FrameLayout>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/_24sdp"
                android:text="Version 1.2.0"
                app:fontFamily="@font/lexend" />



        </LinearLayout>

    </FrameLayout>
</FrameLayout>
